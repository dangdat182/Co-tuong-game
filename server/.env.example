# Sao chép file này thành server/.env và điền giá trị thật
# cp server/.env.example server/.env

# ── Bắt buộc ──────────────────────────────────────────────────────────────────

# JWT secret — đặt chuỗi ngẫu nhiên dài (tối thiểu 32 ký tự)
# Tạo bằng lệnh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_key_here

# ── Tự động khi deploy lên Render/Railway (không cần đổi) ─────────────────────

# Port (Render tự set $PORT, không cần cấu hình thủ công)
PORT=3001

# Môi trường: development | production
NODE_ENV=development

# URL public của app — chỉ cần nếu client và server chạy trên 2 domain khác nhau
# Ví dụ: https://co-tuong.onrender.com
# Để trống nếu server tự serve luôn frontend (cấu hình mặc định khi deploy)
CLIENT_URL=
